---
import { menuInfo } from "../../data/menu-info";
import GlobalSearch from "./global-search";
import LogoNew from "./logo-new.astro";
import { ModeToggle } from "./mode-toggle";
---
<header class="w-full flex items-center justify-between mb-16">
    <a href="/" class="shrink-0 select-none">
        <LogoNew />
    </a>

    <nav class="flex items-center gap-x-4 sm:gap-x-5" aria-label="站点导航">
        {menuInfo.map((item) => (
            <a
                href={item.menuLink}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors"
            >
                {item.menuName}
            </a>
        ))}
        <GlobalSearch client:load />
        <ModeToggle client:load />
    </nav>
</header>

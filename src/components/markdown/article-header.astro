---
import ImageModal from "@/components/common/image-modal";
import { DATE_FORMAT } from "@/constant/constants";
import dayjs from "dayjs";

interface Props {
    title: string;
    publishDate: Date;
    coverImage?: string | null;
    wordCount?: number;
    readingTime?: number;
}

const { title, publishDate, coverImage, wordCount, readingTime } = Astro.props;
---

<header class="mb-10">
    <div class="border-l-4 border-primary pl-3">
        <h1 class="font-reading font-bold text-3xl sm:text-4xl leading-tight text-balance">
            {title}
        </h1>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted-foreground">
        <span class="inline-flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
                <line x1="16" x2="16" y1="2" y2="6"></line>
                <line x1="8" x2="8" y1="2" y2="6"></line>
                <line x1="3" x2="21" y1="10" y2="10"></line>
            </svg>
            <time class="font-mono tabular-nums">{dayjs(publishDate).format(DATE_FORMAT)}</time>
        </span>
        {wordCount ? (
            <span class="inline-flex items-center gap-1.5">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                </svg>
                <span>{wordCount} 字</span>
            </span>
        ) : null}
        {readingTime ? (
            <span class="inline-flex items-center gap-1.5">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <span>约 {readingTime} 分钟</span>
            </span>
        ) : null}
    </div>

    {coverImage && (
        <div class="mt-6 rounded-md overflow-hidden">
            <ImageModal client:load src={coverImage} alt={`${title} 封面图`} />
        </div>
    )}
</header>

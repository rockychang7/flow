---
import { DATE_FORMAT } from "@/constant/constants";
import dayjs from "dayjs";

interface Props {
    title: string;
    date: Date;
    url: string;
}

const {title, date, url} = Astro.props;
---

<a href={url} class="flex items-baseline justify-between gap-4 py-2 px-3 -mx-3 rounded-md transition-colors hover:bg-muted">
    <span class="font-medium min-w-0 break-words">{title}</span>
    <time class="text-caption font-mono tabular-nums text-muted-foreground shrink-0">
        {dayjs(date).format(DATE_FORMAT)}
    </time>
</a>

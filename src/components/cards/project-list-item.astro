---
interface Props {
    title: string;
    description: string;
    url: string;
}

const {title, description, url} = Astro.props;
---

<a href={url} target="_blank" rel="noopener noreferrer"
   class="flex items-baseline justify-between gap-4 py-2 px-3 -mx-3 rounded-md transition-colors hover:bg-muted">
    <span class="min-w-0 break-words">
        <span class="font-medium">{title}</span>
        <span class="text-sm text-muted-foreground"> — {description}</span>
    </span>
    <span class="text-caption font-mono text-muted-foreground shrink-0" aria-hidden="true">↗</span>
</a>

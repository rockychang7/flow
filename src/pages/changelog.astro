---
import SectionHead from "@/components/common/section-head.astro";
import Footer from "@/components/common/footer.astro";
import Header from "@/components/common/header.astro";
import { Badge } from "@/components/ui/badge";
import RootLayout from "@/layouts/RootLayout.astro";
import { changelogs } from "@/data/changelog-info";

const title = "Changelog";
---

<RootLayout title={title}>
    <Header/>

    <div class="flex flex-col">
        <SectionHead title="Changelog" as="h1" />
        <div class="relative ml-2 flex flex-col gap-y-10 border-l border-border pt-3">
            {changelogs.map((log) => (
                <div class="relative pl-6">
                    {/* 时间线节点 */}
                    <span
                        class:list={[
                            "absolute left-[-4.5px] top-1.5 h-2 w-2 rounded-full ring-4 ring-background",
                            log.isMajor ? "bg-foreground" : "bg-faint",
                        ]}
                    ></span>

                    <div class="mb-2 flex items-center gap-3">
                        <span class="font-mono text-caption tabular-nums text-muted-foreground">{log.date}</span>
                        <Badge
                            variant={log.isMajor ? "default" : "secondary"}
                            className="h-5 px-1.5 py-0 text-xs font-mono font-normal"
                        >
                            {log.version}
                        </Badge>
                    </div>

                    <div class="rounded-lg border border-border p-4 transition-colors hover:border-muted-foreground/40">
                        <p class="mb-2 font-medium">{log.description}</p>
                        <ul class="flex flex-col gap-y-1">
                            {log.features.map((feature) => (
                                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                                    <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-muted-foreground/50"></span>
                                    <span>{feature}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <Footer/>
</RootLayout>

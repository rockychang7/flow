---
import SectionHead from "@/components/common/section-head.astro";
import RootLayout from "@/layouts/RootLayout.astro";
import Footer from "../components/common/footer.astro";
import Header from "../components/common/header.astro";

const stacks: [string, string[]][] = [
    ["Coding Agent", ["Claude Code", "Codex", "OpenCode"]],
    ["Frontend", ["HTML", "CSS", "JavaScript", "TypeScript", "React", "Astro", "Next.js", "Vite", "TailwindCSS"]],
    ["Backend", ["Golang", "Java", "MySQL", "Redis", "Kafka", "Docker"]],
    ["Design", ["Stitch"]],
];

const title: string = "关于";
---
<RootLayout title={title} description="关于 Rocky Chang:AI 全栈工程师,记录技术探索、产品构建与个人成长">
    <Header/>
    <div class="flex flex-col gap-y-16">
        <section>
            <SectionHead title="关于" as="h1" />
            <div class="flex flex-col gap-y-4 pt-2 text-pretty leading-relaxed">
                <p>
                    我是 Rocky Chang，一名 AI 全栈工程师，目前专注于 Agent Coding 实践与 Agent 应用开发。
                </p>
                <p>
                    关注 AI 与方法论，热爱一切简单优雅的设计。我会定期在这里<a href="/archive" class="link-inline">撰写文章</a>，分享关于 AI、开发、设计和个人成长的思考。
                </p>
                <p>
                    我热衷于探索 AI 的无限可能，并致力于将前沿技术转化为优雅、实用的产品。在这个快速变化的时代，我坚持追求简单、纯粹的代码与设计美学。
                </p>
            </div>
        </section>

        <section>
            <SectionHead title="本站" />
            <div class="flex flex-col gap-y-4 pt-2 text-pretty leading-relaxed">
                <p>
                    Flow 是我的数字花园，用于记录我在技术探索、产品构建以及个人成长道路上的思考与沉淀。
                </p>
                <p>
                    我希望通过分享高质量的文章和开源项目，与更多志同道合的朋友交流，共同推动 AI 应用的落地与创新。我相信，最好的学习方式就是输出，最好的成长方式就是构建。
                </p>
            </div>
        </section>

        <section>
            <SectionHead title="技术栈" />
            <div class="flex flex-col gap-y-3 pt-2">
                {stacks.map(([label, techs]) => (
                    <div class="flex flex-col gap-y-0.5 sm:flex-row sm:items-baseline sm:gap-x-4">
                        <span class="text-caption text-faint sm:w-28 sm:shrink-0">{label}</span>
                        <span class="text-sm text-muted-foreground">{techs.join(" · ")}</span>
                    </div>
                ))}
            </div>
        </section>

        <section>
            <SectionHead title="联系" />
            <div class="flex flex-col gap-y-4 pt-2 text-pretty leading-relaxed">
                <p>
                    你可以在 <a href="https://github.com/rockychang7" target="_blank" rel="noopener noreferrer" class="link-inline">GitHub</a> 上找到我的开源项目，
                    或者在 <a href="https://twitter.com/rockychang_ai" target="_blank" rel="noopener noreferrer" class="link-inline">Twitter/X</a> 上关注我的最新动态。
                </p>
                <p>
                    如有合作意向或技术交流，欢迎发送邮件至 <a href="mailto:rockychang0318@gmail.com" class="link-inline">rockychang0318@gmail.com</a>。
                </p>
            </div>
        </section>
    </div>
    <Footer/>
</RootLayout>

---
import SectionHead from "@/components/common/section-head.astro";
import ArticleList from "@/components/home/home-article-list.astro";
import ProjectList from "@/components/home/home-project-list.astro";
import ThoughtList from "@/components/home/home-thought-list.astro";
import { getRenderedThoughts } from "@/lib/thoughts";
import RootLayout from "@/layouts/RootLayout.astro";
import Footer from "../components/common/footer.astro";
import Header from "../components/common/header.astro";

const title: string = "Rocky Chang";
const latestThoughts = (await getRenderedThoughts()).slice(0, 3);
---
<RootLayout title={title}>
    <Header/>
    <h1 class="sr-only">Rocky Chang - AI 全栈工程师的个人博客</h1>
    <div class="flex flex-col gap-y-16">
        <section>
            <SectionHead title="文章" moreHref="/archive" />
            <ArticleList/>
        </section>
        {latestThoughts.length > 0 && (
            <section>
                <SectionHead title="想法" moreHref="/thoughts" />
                <ThoughtList thoughts={latestThoughts} />
            </section>
        )}
        <section>
            <SectionHead title="项目" />
            <ProjectList/>
        </section>
    </div>
    <Footer/>
</RootLayout>

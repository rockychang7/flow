---
import { getPublishedArticles, sortByDateDesc } from "@/lib/articles";
import Footer from "../components/common/footer.astro";
import Header from "../components/common/header.astro";
import RootLayout from "../layouts/RootLayout.astro";

import ArticleListItem from "@/components/cards/article-list-item.astro";

const sortBlogPosts = sortByDateDesc(await getPublishedArticles());
const title: string = "Archive";
---
<RootLayout title={title} description="按时间线浏览所有文章">
    <Header/>
    <div class="flex flex-col mt-8 gap-y-4">
        <h1 class="text-sm font-bold text-muted-foreground uppercase tracking-wider border-b border-border/40 pb-2">Archive</h1>
        <div class="flex flex-col gap-y-2">
            {sortBlogPosts.map(post => (
                    <ArticleListItem
                        title={post.data.title}
                        date={post.data.publish_date}
                        url={`/articles/${post.id}`}
                    />
            ))}
        </div>
    </div>

    <Footer/>
</RootLayout>

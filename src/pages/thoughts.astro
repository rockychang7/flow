---
import ThoughtListItem from "@/components/cards/thought-list-item.astro";
import { getRenderedThoughts } from "@/lib/thoughts";
import Footer from "../components/common/footer.astro";
import Header from "../components/common/header.astro";
import RootLayout from "../layouts/RootLayout.astro";

const thoughts = await getRenderedThoughts();
const title: string = "想法";
---
<RootLayout title={title} description="碎片想法与近况时间线">
    <Header/>
    <div class="flex flex-col mt-8 gap-y-4">
        <h1 class="text-sm font-bold text-muted-foreground uppercase tracking-wider border-b border-border/40 pb-2">Thoughts</h1>
        {thoughts.length > 0 ? (
            <div class="relative border-l border-border/50 ml-3 mt-2 space-y-10">
                {thoughts.map((thought) => (
                    <ThoughtListItem html={thought.html} createdAt={thought.createdAt} />
                ))}
            </div>
        ) : (
            <p class="text-muted-foreground">还没有想法。</p>
        )}
    </div>

    <Footer/>
</RootLayout>

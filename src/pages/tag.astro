---
import SectionHead from "@/components/common/section-head.astro";
import { getPublishedArticles } from "@/lib/articles";
import Footer from "../components/common/footer.astro";
import Header from "../components/common/header.astro";
import RootLayout from "../layouts/RootLayout.astro";

const title: string = "标签";
const allBlogPosts = await getPublishedArticles();

// 统计每个标签的文章数
const tagCounts = new Map<string, number>();
for (const post of allBlogPosts) {
    for (const tag of post.data.tags) {
        tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
}
const sortedTags = [...tagCounts.keys()].sort();

// 按文章数把标签分到 5 档:字号 + 灰度同时表达热度
const counts = [...tagCounts.values()];
const min = Math.min(...counts);
const max = Math.max(...counts);
const tiers = [
    "text-sm text-faint",
    "text-base text-muted-foreground",
    "text-lg text-muted-foreground",
    "text-xl text-foreground",
    "text-2xl text-foreground font-medium",
];
const tierClass = (count: number): string => {
    if (max === min) return tiers[2];
    const idx = Math.round(((count - min) / (max - min)) * (tiers.length - 1));
    return tiers[idx];
};
---
<RootLayout title={title} description="按标签浏览所有文章,字号越大表示该主题的文章越多">
    <Header/>
    <div class="flex flex-col">
        <SectionHead title="标签" as="h1" />
        <div class="flex flex-wrap items-baseline gap-x-5 gap-y-3 pt-3">
            {sortedTags.map(tag => (
                <a
                    href={`/tags/${tag}`}
                    class:list={["leading-none transition-colors hover:text-foreground", tierClass(tagCounts.get(tag) ?? 0)]}
                >
                    {tag}<span class="ml-0.5 align-super font-mono text-faint" style="font-size:0.6em">{tagCounts.get(tag)}</span>
                </a>
            ))}
        </div>
    </div>
    <Footer/>
</RootLayout>

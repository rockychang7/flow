---
import TagListItem from "@/components/cards/tag-list-item.astro";
import { getPublishedArticles } from "@/lib/articles";
import Footer from "../components/common/footer.astro";
import Header from "../components/common/header.astro";
import RootLayout from "../layouts/RootLayout.astro";

const title: string = "Tags";
const allBlogPosts = await getPublishedArticles();

// 统计每个标签的文章数
const tagCounts = new Map<string, number>();
for (const post of allBlogPosts) {
    for (const tag of post.data.tags) {
        tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
}
const sortedTags = [...tagCounts.keys()].sort();
---
<RootLayout title={title} description="按标签浏览所有文章">
    <Header/>
    <div class="flex flex-col mt-8 gap-y-4">
        <h1 class="text-sm font-bold text-muted-foreground uppercase tracking-wider border-b border-border/40 pb-2">TAGS</h1>
        <div class="flex flex-wrap gap-x-6 gap-y-3 pt-2">
            {sortedTags.map(tag => (
                <TagListItem
                    name={tag}
                    count={tagCounts.get(tag) ?? 0}
                    url={`/tags/${tag}`}
                />
            ))}
        </div>
    </div>
    <Footer/>
</RootLayout>

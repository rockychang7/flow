---
import ArticleListItem from "@/components/cards/article-list-item.astro";
import SectionHead from "@/components/common/section-head.astro";
import { getPublishedArticles, sortByDateDesc } from "@/lib/articles";
import Footer from "../../components/common/footer.astro";
import Header from "../../components/common/header.astro";
import RootLayout from "../../layouts/RootLayout.astro";

export async function getStaticPaths() {
    const allBlogPosts = await getPublishedArticles();
    const distinctTags = [...new Set(allBlogPosts.flatMap(post => post.data.tags))].sort();

    return distinctTags.map(tag => ({
        params: {tag: tag},
        props: {tag}
    }));
}

const {tag} = Astro.props;
const allBlogPosts = await getPublishedArticles();
const sortBlogPosts = sortByDateDesc(allBlogPosts.filter(post => post.data.tags.includes(tag)));
---
<RootLayout title={`标签 / ${tag}`} description={`标签「${tag}」下的所有文章`}>
    <Header/>
    <div class="flex flex-col">
        <SectionHead title={`标签 / ${tag}`} as="h1" />
        <div class="flex flex-col">
            {sortBlogPosts.map(post => (
                <ArticleListItem
                    title={post.data.title}
                    date={post.data.publish_date}
                    url={`/articles/${post.id}`}
                />
            ))}
        </div>
    </div>
    <Footer/>
</RootLayout>
